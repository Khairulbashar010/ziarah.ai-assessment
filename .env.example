NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Redis — required for query cache, result store, and refresh locks
REDIS_URL=redis://localhost:6379

# Provider mode — MOCK_PROVIDERS=false enables live APIs; override per provider below
MOCK_PROVIDERS=true
# MOCK_SABRE=true
# MOCK_AMADEUS=true
# MOCK_HOTELBEDS=true
# false + OPENAI_API_KEY = live NL parsing; true = regex-only (CI / load tests)
MOCK_LLM=false
MOCK_LATENCY_MS_MIN=200
MOCK_LATENCY_MS_MAX=800
# 0–1 probability of random provider failure in mock mode (deterministic triggers still apply)
MOCK_FAILURE_RATE=0
PROVIDER_TIMEOUT_MS=2500
# Retry failed providers once when fewer than 2 of 3 succeed (set false to disable)
# PROVIDER_QUORUM_RETRY=true
PROVIDER_RETRY_TIMEOUT_MS=1000
GLOBAL_TIMEOUT_MS=3000
# Sync POST /api/trips/search — LLM budget before regex fallback (stream uses LLM_PARSE_TIMEOUT_MS)
SYNC_LLM_PARSE_TIMEOUT_MS=800

# OpenAI — used first when OPENAI_API_KEY is set; set MOCK_LLM=true to force regex-only parsing (CI / load tests)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Stable key for OpenAI prompt-cache routing (system prompt + JSON schema prefix)
OPENAI_PROMPT_CACHE_KEY=ziarah-trip-parse
LLM_PARSE_TIMEOUT_MS=12000

# Mockaroo — optional Sabre, Amadeus, and HotelBeds mock seed generation (https://www.mockaroo.com)
# MOCKAROO_API_KEY=

# Sabre — CERT sandbox: https://api.test.sabre.com
# Register at https://developer.sabre.com → My Apps
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_PCC=
SABRE_ENV=cert

# Amadeus — test sandbox: https://test.api.amadeus.com
# Self-service portal is closing; Enterprise access requires sales onboarding
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# HotelBeds — test sandbox: https://api.test.hotelbeds.com
# Register at https://developer.hotelbeds.com (50 req/day evaluation tier)
HOTELBEDS_API_KEY=
HOTELBEDS_API_SECRET=
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

# Cache & client payload limits
TRIP_SEARCH_CACHE_TTL_MS=300000
CLIENT_MAX_FLIGHT_OFFERS=50
CLIENT_MAX_HOTEL_OFFERS=30

# Docker Compose — host port mapped to container PORT (default 3000)
# HOST_PORT=3000
# REDIS_HOST_PORT=6379

# Structured logging (JSON to stdout → Promtail → Loki)
# LOG_LEVEL=info
# SERVICE_NAME=ziarah-trip-search

# Grafana / Loki (docker compose observability stack)
# GRAFANA_HOST_PORT=3001
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
# LOKI_HOST_PORT=3100
