{
  "name": "ziarah-trip-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:mocks": "node scripts/generate-mock-seeds.mjs",
    "loadtest:smoke": "k6 run -e BASE_URL=http://localhost:3000 load/smoke.js",
    "loadtest:sync": "k6 run -e BASE_URL=http://localhost:3000 load/search-sync.js",
    "loadtest:stream": "k6 run -e BASE_URL=http://localhost:3000 -e K6_TARGET_VUS=30 load/search-stream.js",
    "loadtest:capacity": "k6 run -e BASE_URL=http://localhost:3000 -e K6_TARGET_VUS=100 load/capacity.js",
    "loadtest:docker:smoke": "docker compose --profile loadtest run --rm k6 run /scripts/smoke.js",
    "loadtest:docker:sync": "docker compose --profile loadtest run --rm k6 run /scripts/search-sync.js",
    "loadtest:docker:stream": "docker compose --profile loadtest run --rm -e K6_TARGET_VUS=30 k6 run /scripts/search-stream.js",
    "loadtest:docker:capacity": "docker compose --profile loadtest run --rm -e K6_TARGET_VUS=100 k6 run /scripts/capacity.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "redis": "^6.0.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
